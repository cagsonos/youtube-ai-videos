# YouTube Data API v3 — obtener en https://console.cloud.google.com
# Habilitar "YouTube Data API v3" en APIs & Services
YOUTUBE_API_KEY=

# OpenRouter API — obtener en https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Turso (base de datos libSQL) — usar en dev y producción
# Crear en https://turso.tech o via CLI: turso db create youtube-ai-videos
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
